# GitHub API — Personal Access Token
# Create at: https://github.com/settings/tokens
# Required scopes: read:user, public_repo
GITHUB_TOKEN=ghp_your_token_here

# Your GitHub username
GITHUB_USERNAME=YoniLevy10

# Public GitHub username (used in client-side image URLs)
NEXT_PUBLIC_GITHUB_USERNAME=YoniLevy10

# Your site URL (used for absolute OG image URLs)
NEXT_PUBLIC_SITE_URL=https://levytech.dev

# Optional: GitHub Webhook secret for instant revalidation
# WEBHOOK_SECRET=your_random_secret_here
